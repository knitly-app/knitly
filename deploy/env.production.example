# Knitly Production Environment
# Copy to server/.env.production and fill in your values

NODE_ENV=production
PORT=3000
BASE_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com

# Database (SQLite)
# Path relative to server/ directory, or absolute
DATABASE_PATH=../knitly.db

# Uploads — local filesystem (default)
# Set to false and configure S3 below for cloud storage
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=../uploads

# Uploads — S3-compatible storage (optional)
# If configured, set USE_LOCAL_STORAGE=false
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=nyc3
# SPACES_BUCKET=your-bucket-name
# SPACES_KEY=your-access-key
# SPACES_SECRET=your-secret-key
# SPACES_PUBLIC_URL=https://your-bucket-name.nyc3.cdn.digitaloceanspaces.com

# Upload limits
# MAX_UPLOAD_BYTES=10485760
# MEDIA_MAX_DIMENSION=2048
# MEDIA_QUALITY=82

# Admin seed (used by `bun --cwd server run seed`)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme123
# ADMIN_USERNAME=admin
# ADMIN_DISPLAY_NAME=Admin
