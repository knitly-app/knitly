# Knitly Environment Configuration
# Copy to .env (development) or server/.env.production (production)
# See deploy/env.production.example for production-specific settings

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Database
DATABASE_PATH=../knitly.db

# Uploads (local filesystem)
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=../uploads

# Admin seed credentials (used by `bun --cwd server run seed`)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=changeme123

# Email (optional — uses Resend. Without this, emails log to console)
# RESEND_API_KEY=re_xxxxx
# FROM_EMAIL=noreply@yourdomain.com

# S3-compatible storage (optional — overrides local storage)
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=nyc3
# SPACES_BUCKET=
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_PUBLIC_URL=
