{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/setup-react-shim.js",
    "dev": "vite",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test src/test",
    "test:unit": "bun test src/test/unit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.88",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.157.18",
    "ai": "^6.0.86",
    "autoprefixer": "^10.4.24",
    "lucide-preact": "^0.563.0",
    "postcss": "^8.5.6",
    "preact": "^10.27.2",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.51.1",
    "@preact/preset-vite": "^2.10.2",
    "@preact/signals": "^2.6.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.2.10",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^7.2.4"
  }
}
