{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "paths": {
      "react": ["./node_modules/preact/compat/"],
      "react-dom": ["./node_modules/preact/compat/"],
      "@knitly/*": ["./src/*"],
      "preact": ["./node_modules/preact"],
      "preact/hooks": ["./node_modules/preact/hooks"],
      "preact/compat": ["./node_modules/preact/compat"],
      "preact/jsx-runtime": ["./node_modules/preact/jsx-runtime"],
      "lucide-preact": ["./node_modules/lucide-preact"],
      "@tanstack/react-query": ["./node_modules/@tanstack/react-query"],
      "@ai-sdk/react": ["./node_modules/@ai-sdk/react"],
      "ai": ["./node_modules/ai"]
    },

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "../custom/frontend"],
  "exclude": ["src/__tests__", "src/test"]
}
